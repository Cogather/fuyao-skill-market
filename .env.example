# Skill 市场接口：`mock` | `http`
VITE_SKILL_MARKET_TRANSPORT=mock
# 后端 API 根路径（http 模式），空表示与页面同源
VITE_SKILL_MARKET_API_BASE=

# 以下两项仅在 VITE_SKILL_MARKET_TRANSPORT=mock 时生效；=http 时即使保留在 .env 也会被忽略
# mock 模式：模拟角色 USER | ORG_ADMIN | SUPER_ADMIN（不填则 ORG_ADMIN）
# VITE_SKILL_MARKET_MOCK_ROLE=USER
# mock + ORG_ADMIN：管辖组织 id，逗号分隔；不填则包含全部种子组织
# VITE_SKILL_MARKET_MOCK_MANAGED_ORG_IDS=1,5
